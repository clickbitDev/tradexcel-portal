generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  manager
  staff
  agent
  ceo
  executive_manager
  accounts_manager
  assessor
  dispatch_coordinator
  frontdesk
  developer

  @@map("user_role")
}

enum QualificationStatus {
  current
  superseded
  deleted

  @@map("qualification_status")
}

enum TgaSyncStatus {
  synced
  pending
  error
  never

  @@map("tga_sync_status")
}

enum RtoStatus {
  active
  pending
  suspended
  inactive

  @@map("rto_status")
}

enum PartnerType {
  agent
  provider
  subagent

  @@map("partner_type")
}

enum PartnerStatus {
  active
  pending
  suspended
  inactive

  @@map("partner_status")
}

enum PriorityLevel {
  standard
  preferred
  premium

  @@map("priority_level")
}

enum WorkflowStage {
  TRANSFERRED
  docs_review
  rto_processing
  offer_issued
  payment_pending
  coe_issued
  visa_applied
  enrolled
  evaluate
  accounts
  dispatch
  completed
  withdrawn
  rejected

  @@map("workflow_stage")
}

enum PaymentStatus {
  unpaid
  partial
  paid
  refunded

  @@map("payment_status")
}

enum TicketStatus {
  open
  in_progress
  waiting
  resolved
  closed

  @@map("ticket_status")
}

enum TicketPriority {
  low
  normal
  high
  urgent

  @@map("ticket_priority")
}

enum NotificationChannel {
  email
  whatsapp
  sms

  @@map("notification_channel")
}

enum NotificationStatus {
  pending
  sent
  failed
  cancelled

  @@map("notification_status")
}

enum ReminderStatus {
  active
  paused
  completed
  expired

  @@map("reminder_status")
}

enum QuerySourceType {
  web_form
  api
  manual
  import
  referral
  walk_in

  @@map("query_source_type")
}

enum ContactChannel {
  email
  phone
  whatsapp
  meeting
  other

  @@map("contact_channel")
}

enum SyncResult {
  success
  partial
  failed
  skipped

  @@map("sync_result")
}

enum NotificationType {
  application_update
  document_uploaded
  document_verified
  comment_added
  mention
  payment_received
  reminder
  approval_required
  partner_update
  system_alert
  welcome
  deadline_warning
  assignment

  @@map("notification_type")
}

enum BillStatus {
  pending
  received
  paid
  overdue
  cancelled

  @@map("bill_status")
}

enum BulkOperationType {
  invoice
  bill

  @@map("bulk_operation_type")
}

enum BulkOperationStatus {
  pending
  processing
  completed
  failed

  @@map("bulk_operation_status")
}

enum DocumentTypeEnum {
  passport
  visa
  drivers_license
  qualification
  resume
  academic_transcript
  english_test
  coe
  offer_letter
  invoice
  bill
  other

  @@map("document_type_enum")
}

enum AccountStatus {
  active
  disabled

  @@map("account_status")
}

enum AssessmentResult {
  pending
  pass
  failed

  @@map("assessment_result")
}

enum ApplicationOutcome {
  active
  withdrawn
  rejected

  @@map("application_outcome")
}

model Profile {
  id               String        @id @db.Uuid
  full_name        String        @db.Text
  email            String        @db.Text
  role             UserRole      @default(agent)
  avatar_url       String?       @db.Text
  phone            String?       @db.Text
  created_at       DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?     @default(now()) @db.Timestamptz(6)
  is_deleted       Boolean?      @default(false)
  deleted_at       DateTime?     @db.Timestamptz(6)
  deleted_by       String?       @db.Uuid
  company_name     String?       @db.Text
  secondary_emails String[]      @default([])
  social_links     Json?         @default(dbgenerated("'{}'::jsonb")) @db.JsonB
  assessor_rate    Decimal?      @db.Decimal(10, 2)
  account_status   AccountStatus @default(active)

  @@index([role], map: "idx_profiles_role")
  @@index([deleted_by], map: "idx_profiles_deleted_by")
  @@index([account_status], map: "idx_profiles_account_status")
  @@map("profiles")
}

model Qualification {
  id                           String               @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                         String               @unique @db.Text
  name                         String               @db.Text
  level                        String?              @db.Text
  status                       QualificationStatus? @default(current)
  release_date                 DateTime?            @db.Date
  superseded_by                String?              @db.Text
  tga_sync_status              TgaSyncStatus?       @default(never)
  tga_last_synced_at           DateTime?            @db.Timestamptz(6)
  created_at                   DateTime?            @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime?            @default(now()) @db.Timestamptz(6)
  is_archived                  Boolean?             @default(false)
  archived_at                  DateTime?            @db.Timestamptz(6)
  archived_by                  String?              @db.Uuid
  is_deleted                   Boolean?             @default(false)
  deleted_at                   DateTime?            @db.Timestamptz(6)
  deleted_by                   String?              @db.Uuid
  core_units                   Int?
  elective_units               Int?
  total_units                  Int?
  entry_requirements           String?              @db.Text
  cricos_code                  String?              @db.VarChar(20)
  delivery_mode                String[]             @default([])
  last_edited_by               String?              @db.Uuid
  prerequisites                String[]             @default([])
  certificate_preview_path     String?              @db.Text
  certificate_preview_provider String?              @db.Text
  certificate_preview_bucket   String?              @db.Text
  certificate_preview_key      String?              @db.Text

  @@index([code], map: "idx_qualifications_code")
  @@index([archived_by], map: "idx_qualifications_archived_by")
  @@index([deleted_by], map: "idx_qualifications_deleted_by")
  @@index([last_edited_by], map: "idx_qualifications_last_edited_by")
  @@map("qualifications")
}

model Rto {
  id                   String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  code                 String         @unique @db.Text
  name                 String         @db.Text
  logo_url             String?        @db.Text
  status               RtoStatus?     @default(active)
  location             String?        @db.Text
  state                String?        @db.Text
  phone                String?        @db.Text
  email                String?        @db.Text
  website              String?        @db.Text
  notes                String?        @db.Text
  created_at           DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at           DateTime?      @default(now()) @db.Timestamptz(6)
  cricos_provider_code String?        @db.VarChar(20)
  delivery_modes       String[]       @default([])
  certificate_types    String[]       @default([])
  tga_sync_status      TgaSyncStatus? @default(never)
  tga_last_synced_at   DateTime?      @db.Timestamptz(6)
  tga_sync_error       String?        @db.Text
  is_archived          Boolean?       @default(false)
  archived_at          DateTime?      @db.Timestamptz(6)
  archived_by          String?        @db.Uuid
  is_deleted           Boolean?       @default(false)
  deleted_at           DateTime?      @db.Timestamptz(6)
  deleted_by           String?        @db.Uuid
  contact_person_name  String?        @db.Text
  assigned_manager_id  String?        @db.Uuid
  provider_name        String?        @db.Text
  xero_contact_id      String?        @db.VarChar(100)
  xero_contact_url     String?        @db.VarChar(500)

  @@index([code], map: "idx_rtos_code")
  @@index([tga_sync_status], map: "idx_rtos_tga_sync_status")
  @@index([archived_by], map: "idx_rtos_archived_by")
  @@index([deleted_by], map: "idx_rtos_deleted_by")
  @@index([assigned_manager_id], map: "idx_rtos_assigned_manager")
  @@map("rtos")
}

model RtoOffering {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  rto_id               String    @db.Uuid
  qualification_id     String    @db.Uuid
  tuition_fee_onshore  Decimal?  @db.Decimal(10, 2)
  tuition_fee_offshore Decimal?  @db.Decimal(10, 2)
  material_fee         Decimal?  @default(0) @db.Decimal(10, 2)
  application_fee      Decimal?  @default(0) @db.Decimal(10, 2)
  duration_weeks       Int?
  intakes              String[]  @default([])
  is_active            Boolean?  @default(true)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  effective_date       DateTime? @default(dbgenerated("CURRENT_DATE")) @db.Date
  expiry_date          DateTime? @db.Date
  version              Int?      @default(1)
  approval_status      String?   @default("published") @db.VarChar(20)
  is_archived          Boolean?  @default(false)
  archived_at          DateTime? @db.Timestamptz(6)
  archived_by          String?   @db.Uuid
  is_deleted           Boolean?  @default(false)
  deleted_at           DateTime? @db.Timestamptz(6)
  deleted_by           String?   @db.Uuid
  agent_fee            Decimal?  @default(0) @db.Decimal(10, 2)
  lumiere_fee          Decimal?  @default(0) @db.Decimal(10, 2)
  student_fee          Decimal?  @default(0) @db.Decimal(10, 2)
  enrollment_fee       Decimal?  @default(0) @db.Decimal(10, 2)
  misc_fee             Decimal?  @default(0) @db.Decimal(10, 2)
  assessor_fee         Decimal?  @default(0) @db.Decimal(10, 2)
  provider_fee         Decimal?  @default(0) @db.Decimal(10, 2)

  @@unique([rto_id, qualification_id], map: "rto_offerings_rto_id_qualification_id_key")
  @@index([rto_id], map: "idx_rto_offerings_rto")
  @@index([qualification_id], map: "idx_rto_offerings_qual")
  @@index([archived_by], map: "idx_rto_offerings_archived_by")
  @@index([deleted_by], map: "idx_rto_offerings_deleted_by")
  @@map("rto_offerings")
}

model Partner {
  id                  String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  type                PartnerType
  company_name        String          @db.Text
  contact_name        String?         @db.Text
  email               String?         @unique @db.Text
  phone               String?         @db.Text
  address             String?         @db.Text
  country             String?         @db.Text
  commission_rate     Decimal?        @db.Decimal(5, 2)
  priority_level      PriorityLevel?  @default(standard)
  user_id             String?         @db.Uuid
  status              PartnerStatus?  @default(active)
  notes               String?         @db.Text
  created_at          DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?       @default(now()) @db.Timestamptz(6)
  delivery_method     String?         @db.VarChar(50)
  kpi_ontime_rate     Decimal?        @db.Decimal(5, 2)
  kpi_conversion_rate Decimal?        @db.Decimal(5, 2)
  assigned_manager_id String?         @db.Uuid
  is_archived         Boolean?        @default(false)
  archived_at         DateTime?       @db.Timestamptz(6)
  archived_by         String?         @db.Uuid
  is_deleted          Boolean?        @default(false)
  deleted_at          DateTime?       @db.Timestamptz(6)
  deleted_by          String?         @db.Uuid
  preferred_channel   ContactChannel?
  linked_rto_id       String?         @db.Uuid
  parent_partner_id   String?         @db.Uuid
  xero_contact_id     String?         @db.VarChar(100)
  xero_contact_url    String?         @db.VarChar(500)

  @@index([assigned_manager_id], map: "idx_partners_assigned_manager")
  @@index([linked_rto_id], map: "idx_partners_linked_rto")
  @@index([parent_partner_id], map: "idx_partners_parent_partner")
  @@index([user_id], map: "idx_partners_user")
  @@index([archived_by], map: "idx_partners_archived_by")
  @@index([deleted_by], map: "idx_partners_deleted_by")
  @@map("partners")
}

model StudentMaster {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  first_name       String    @db.VarChar(100)
  last_name        String    @db.VarChar(100)
  email            String?   @db.VarChar(255)
  phone            String?   @db.VarChar(50)
  passport_number  String?   @db.VarChar(50)
  nationality      String?   @db.VarChar(100)
  dob              DateTime? @db.Date
  address          String?   @db.Text
  created_at       DateTime? @default(now()) @db.Timestamptz(6)
  updated_at       DateTime? @default(now()) @db.Timestamptz(6)
  is_deleted       Boolean?  @default(false)
  deleted_at       DateTime? @db.Timestamptz(6)
  deleted_by       String?   @db.Uuid
  usi              String?   @db.VarChar(20)
  visa_number      String?   @db.VarChar(50)
  visa_expiry      DateTime? @db.Date
  gender           String?   @db.VarChar(20)
  country_of_birth String?   @db.VarChar(100)
  street_no        String?   @db.Text
  suburb           String?   @db.VarChar(100)
  state            String?   @db.VarChar(50)
  postcode         String?   @db.VarChar(20)

  @@index([deleted_by], map: "idx_student_master_deleted_by")
  @@index([email], map: "idx_student_master_email")
  @@index([passport_number], map: "idx_student_master_passport")
  @@index([last_name, first_name], map: "idx_student_master_name")
  @@map("student_master")
}

model Application {
  id                                       String                   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  student_uid                              String                   @unique @db.Text
  student_first_name                       String                   @db.Text
  student_last_name                        String                   @db.Text
  student_email                            String?                  @db.Text
  student_phone                            String?                  @db.Text
  student_dob                              DateTime?                @db.Date
  student_passport_number                  String?                  @db.Text
  student_nationality                      String?                  @db.Text
  partner_id                               String?                  @db.Uuid
  offering_id                              String?                  @db.Uuid
  workflow_stage                           WorkflowStage?           @default(docs_review)
  source_application_id                    String?                  @db.Uuid
  source_portal                            String                   @default("local") @db.Text
  source_rto_id                            String?                  @db.Uuid
  source_qualification_code                String?                  @db.Text
  transferred_at                           DateTime?                @db.Timestamptz(6)
  transfer_event_id                        String?                  @db.Text
  payment_status                           PaymentStatus?           @default(unpaid)
  quoted_tuition                           Decimal?                 @db.Decimal(10, 2)
  quoted_materials                         Decimal?                 @db.Decimal(10, 2)
  total_paid                               Decimal?                 @default(0) @db.Decimal(10, 2)
  appointment_date                         DateTime?                @db.Date
  appointment_time                         DateTime?                @db.Time(6)
  submitted_at                             DateTime?                @db.Timestamptz(6)
  coe_issued_at                            DateTime?                @db.Timestamptz(6)
  documents                                Json?                    @default(dbgenerated("'[]'::jsonb")) @db.JsonB
  created_by                               String?                  @db.Uuid
  assigned_to                              String?                  @db.Uuid
  created_at                               DateTime?                @default(now()) @db.Timestamptz(6)
  updated_at                               DateTime?                @default(now()) @db.Timestamptz(6)
  assigned_staff_id                        String?                  @db.Uuid
  locked_by                                String?                  @db.Uuid
  lock_timestamp                           DateTime?                @db.Timestamptz(6)
  student_master_id                        String?                  @db.Uuid
  query_source                             QuerySourceType?
  query_source_id                          String?                  @db.VarChar(100)
  lead_source_id                           String?                  @db.Uuid
  referrer_url                             String?                  @db.Text
  is_archived                              Boolean?                 @default(false)
  archived_at                              DateTime?                @db.Timestamptz(6)
  archived_by                              String?                  @db.Uuid
  is_deleted                               Boolean?                 @default(false)
  deleted_at                               DateTime?                @db.Timestamptz(6)
  deleted_by                               String?                  @db.Uuid
  student_gender                           String?                  @db.VarChar(20)
  student_country_of_birth                 String?                  @db.VarChar(100)
  application_from                         String?                  @db.VarChar(100)
  student_street_no                        String?                  @db.Text
  student_suburb                           String?                  @db.VarChar(100)
  student_state                            String?                  @db.VarChar(50)
  student_postcode                         String?                  @db.VarChar(20)
  received_by                              String?                  @db.Uuid
  received_at                              DateTime?                @db.Timestamptz(6)
  last_updated_by                          String?                  @db.Uuid
  notes                                    String?                  @db.Text
  issue_date                               DateTime?                @db.Date
  signed_off_by                            String?                  @db.Uuid
  signed_off_at                            DateTime?                @db.Timestamptz(6)
  assigned_by                              String?                  @db.Uuid
  assigned_at                              DateTime?                @db.Timestamptz(6)
  needs_attention                          Boolean?                 @default(false)
  ready_to_check                           Boolean?                 @default(false)
  ready_to_check_at                        DateTime?                @db.Timestamptz(6)
  docs_prepared_by                         String?                  @db.Uuid
  docs_prepared_at                         DateTime?                @db.Timestamptz(6)
  docs_checked_by                          String?                  @db.Uuid
  docs_checked_at                          DateTime?                @db.Timestamptz(6)
  docs_approved_by                         String?                  @db.Uuid
  docs_approved_at                         DateTime?                @db.Timestamptz(6)
  provider_email                           String?                  @db.VarChar(255)
  additional_emails                        String[]                 @default([])
  sent_by                                  String?                  @db.Uuid
  sent_at                                  DateTime?                @db.Timestamptz(6)
  delivery_method                          String?                  @db.VarChar(50)
  delivered_by                             String?                  @db.Uuid
  delivery_date                            DateTime?                @db.Date
  tracking_url                             String?                  @db.Text
  is_delivered                             Boolean?                 @default(false)
  has_qualifications_docs                  Boolean?                 @default(false)
  has_id_docs                              Boolean?                 @default(false)
  has_misc_docs                            Boolean?                 @default(false)
  student_address                          String?                  @db.Text
  student_usi                              String?                  @db.VarChar(10)
  student_visa_number                      String?                  @db.VarChar(50)
  student_visa_expiry                      DateTime?                @db.Date
  has_invoice                              Boolean?                 @default(false)
  latest_invoice_id                        String?                  @db.Uuid
  invoice_sent_at                          DateTime?                @db.Timestamptz(6)
  has_bill                                 Boolean?                 @default(false)
  latest_bill_id                           String?                  @db.Uuid
  bill_created_at                          DateTime?                @db.Timestamptz(6)
  lock_timeout                             Unsupported("interval")?
  assigned_assessor_id                     String?                  @db.Uuid
  assigned_admin_id                        String?                  @db.Uuid
  assessor_fee                             Decimal?                 @default(0) @db.Decimal(10, 2)
  xero_invoice_id                          String?                  @db.VarChar(100)
  xero_invoice_number                      String?                  @db.VarChar(50)
  xero_invoice_status                      String?                  @db.VarChar(30)
  xero_invoice_url                         String?                  @db.VarChar(500)
  xero_bill_id                             String?                  @db.VarChar(100)
  xero_bill_number                         String?                  @db.VarChar(50)
  xero_bill_status                         String?                  @db.VarChar(30)
  xero_bill_url                            String?                  @db.VarChar(500)
  xero_last_synced_at                      DateTime?                @db.Timestamptz(6)
  application_number                       String                   @unique @db.Text
  workflow_stage_updated_at                DateTime                 @default(now()) @db.Timestamptz(6)
  qualification_id                         String?                  @db.Uuid
  admin_applicant_pdf_email_completed      Boolean                  @default(false)
  admin_applicant_pdf_email_completed_at   DateTime?                @db.Timestamptz(6)
  admin_applicant_pdf_email_completed_by   String?                  @db.Uuid
  admin_references_email_completed         Boolean                  @default(false)
  admin_references_email_completed_at      DateTime?                @db.Timestamptz(6)
  admin_references_email_completed_by      String?                  @db.Uuid
  agent_applicant_pdf_email_completed      Boolean                  @default(false)
  agent_applicant_pdf_email_completed_at   DateTime?                @db.Timestamptz(6)
  agent_applicant_pdf_email_completed_by   String?                  @db.Uuid
  agent_references_email_completed         Boolean                  @default(false)
  agent_references_email_completed_at      DateTime?                @db.Timestamptz(6)
  agent_references_email_completed_by      String?                  @db.Uuid
  agent_enrollment_agreement_uploaded      Boolean                  @default(false)
  agent_enrollment_agreement_uploaded_at   DateTime?                @db.Timestamptz(6)
  agent_enrollment_agreement_uploaded_by   String?                  @db.Uuid
  agent_enrollment_agreement_document_id   String?                  @db.Uuid
  agent_executive_manager_notified         Boolean                  @default(false)
  agent_executive_manager_notified_at      DateTime?                @db.Timestamptz(6)
  agent_executive_manager_notified_by      String?                  @db.Uuid
  assessment_result                        AssessmentResult         @default(pending)
  assessment_result_at                     DateTime?                @db.Timestamptz(6)
  assessment_result_by                     String?                  @db.Uuid
  evaluation_started_at                    DateTime?                @db.Timestamptz(6)
  evaluation_started_by                    String?                  @db.Uuid
  assessment_report_date                   DateTime?                @db.Date
  assessment_report_start_time             DateTime?                @db.Time(6)
  assessment_report_end_time               DateTime?                @db.Time(6)
  assessment_report_venue                  String?                  @db.VarChar(50)
  assessment_report_virtual_platform       String?                  @db.VarChar(50)
  assessment_report_meeting_record_document_id String?              @db.Uuid
  assessment_report_outcome                String?                  @db.Text
  assessment_report_overview               String?                  @db.Text
  assessment_report_recommendation         String?                  @db.Text
  assessment_report_completed_at           DateTime?                @db.Timestamptz(6)
  assessment_report_completed_by           String?                  @db.Uuid
  dispatch_approval_requested_at           DateTime?                @db.Timestamptz(6)
  dispatch_approval_requested_by           String?                  @db.Uuid
  dispatch_approval_approved_at            DateTime?                @db.Timestamptz(6)
  dispatch_approval_approved_by            String?                  @db.Uuid
  dispatch_override_used                   Boolean                  @default(false)
  application_outcome                      ApplicationOutcome       @default(active)
  agent_frontdesk_notified                 Boolean                  @default(false)
  agent_frontdesk_notified_at              DateTime?                @db.Timestamptz(6)
  agent_frontdesk_notified_by              String?                  @db.Uuid
  admin_accounts_manager_bill_requested    Boolean                  @default(false)
  admin_accounts_manager_bill_requested_at DateTime?                @db.Timestamptz(6)
  admin_accounts_manager_bill_requested_by String?                  @db.Uuid

  @@index([workflow_stage], map: "idx_applications_stage")
  @@index([source_application_id], map: "idx_applications_source_application_id")
  @@index([source_portal], map: "idx_applications_source_portal")
  @@index([partner_id], map: "idx_applications_partner")
  @@index([student_uid], map: "idx_applications_uid")
  @@index([received_by], map: "idx_applications_received_by")
  @@index([assigned_by], map: "idx_applications_assigned_by")
  @@index([archived_by], map: "idx_applications_archived_by")
  @@index([assigned_staff_id], map: "idx_applications_assigned_staff")
  @@index([assigned_to], map: "idx_applications_assigned_to")
