# Compose app envs: used by `docker-compose.yml` for `web`
OWNER_PASSWORD=replace-with-strong-owner-password
USER_PASSWORD=
CORS_ORIGIN=https://portal.yourdomain.com
ALLOW_REMOTE_IMAGE_FETCH=false
ALLOWED_IMAGE_HOSTS=
TEMPLATE_PATH=

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

BACKBLAZE_BUCKET_ENDPOINT=https://s3.your-region.backblazeb2.com
BACKBLAZE_ACCESS_KEY_ID=replace-with-key-id
BACKBLAZE_SECRET_ACCESS_KEY=replace-with-app-key
BACKBLAZE_APPLICATION_BUCKETNAME=replace-with-bucket-name
BACKBLAZE_BUCKET_REGION=replace-with-region

# Web service envs: required by the public `web` service in this compose stack
DATABASE_URL=postgresql://user:password@your-db-host:5432/postgres
DIRECT_URL=postgresql://user:password@your-db-host:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-anon-key
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=replace-with-browser-key
GOOGLE_MAPS_API_KEY=replace-with-browser-key
NEXT_PUBLIC_SITE_URL=https://portal.yourdomain.com
ENABLE_DETAILED_PROD_ERRORS=false

# Web service Xero envs: used by `web`, not by `pdf-secure` or `pdf-worker`
XERO_CLIENT_ID=replace-with-client-id
XERO_CLIENT_SECRET=replace-with-client-secret
XERO_REDIRECT_URI=https://portal.yourdomain.com/api/auth/callback/xero
XERO_SALES_ACCOUNT_CODE=200
XERO_PURCHASES_ACCOUNT_CODE=300
XERO_SALES_TAX_TYPE=OUTPUT
XERO_PURCHASES_TAX_TYPE=INPUT
XERO_PAYMENT_ACCOUNT_CODE=090
XERO_MCP_ENABLED=false
XERO_MCP_COMMAND=
XERO_MCP_SERVER_PATH=
XERO_MCP_ARGS=

# Web service notifications/email envs
INFOBIP_API_KEY=
INFOBIP_BASE_URL=
INFOBIP_SMS_SENDER=
INFOBIP_WHATSAPP_SENDER=

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
EMAIL_FROM=
SSL_PORT=465
TLS_PORT=587
USER_NAME=replace-with-email-username
PASSWORD=replace-with-email-password
CRON_SECRET=replace-with-random-cron-secret
